---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Button } from "@/components/ui/button";
---

<BaseLayout title="페이지를 찾을 수 없음">
  <div class="flex flex-col items-start gap-4 py-16">
    <p class="text-5xl font-bold">404</p>
    <p class="text-muted-foreground">요청하신 페이지를 찾을 수 없습니다.</p>
    <Button asChild>
      <a href="/">홈으로 돌아가기</a>
    </Button>
  </div>
</BaseLayout>
