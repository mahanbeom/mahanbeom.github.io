---
import type { CollectionEntry } from "astro:content";

import { formatDate } from "@/lib/utils";
import { Badge } from "@/components/ui/badge";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<a href={`/blog/${post.id}/`} class="group block">
  <Card className="transition-colors group-hover:border-ring/60 group-hover:bg-accent/40">
    <CardHeader className="pb-3">
      <div class="mb-1 flex items-center gap-2 text-xs text-muted-foreground">
        <Badge variant="outline">{post.data.category}</Badge>
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      </div>
      <CardTitle className="text-lg leading-snug group-hover:underline group-hover:underline-offset-4">
        {post.data.title}
      </CardTitle>
      <CardDescription className="line-clamp-2 leading-relaxed">
        {post.data.description}
      </CardDescription>
    </CardHeader>
    {
      post.data.tags.length > 0 && (
        <CardContent className="pt-0">
          <div class="flex flex-wrap gap-1.5">
            {post.data.tags.map((tag) => (
              <span class="text-xs text-muted-foreground">#{tag}</span>
            ))}
          </div>
        </CardContent>
      )
    }
  </Card>
</a>
